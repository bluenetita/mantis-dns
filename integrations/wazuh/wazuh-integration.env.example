# Copy to /etc/mantis/wazuh-integration.env and chmod 600 (root-only read).
# Consumed by run-mantis-pull.sh.

MANTIS_API_URL=https://mantis-control.internal:8443/api/v1

# Dedicated operator (or admin) account for this integration — do not reuse
# an interactive admin login. The account only needs the "operator" role,
# which is enough for GET /siem/events (see require_role("admin", "operator")
# in siem_routers.py).
MANTIS_EMAIL=siem-pull@example.com
MANTIS_PASSWORD=changeme

# Optional scoping — leave unset to pull every tenant/decision visible to
# the account above.
#MANTIS_TENANT_ID=
#MANTIS_DECISION=block

MANTIS_STATE_FILE=/var/ossec/var/mantis/cursor.txt
MANTIS_OUTPUT_FILE=/var/ossec/logs/mantis/siem-events.json
