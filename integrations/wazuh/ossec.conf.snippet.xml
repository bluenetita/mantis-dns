<!-- Periodically pulls Mantis DNS SIEM events (design.md §20.3) into a
     local JSON log file. Wazuh has no generic inbound webhook receiver,
     so pull — not the Mantis "webhook push" feature — is the supported
     integration path. -->
<wodle name="command">
  <disabled>no</disabled>
  <tag>mantis-siem-pull</tag>
  <command>/var/ossec/integrations/mantis/run-mantis-pull.sh</command>
  <interval>1m</interval>
  <ignore_output>no</ignore_output>
  <run_on_start>yes</run_on_start>
  <timeout>90</timeout>
</wodle>

<!-- Wazuh's built-in JSON decoder parses this natively; no <log_format>
     other than "json" is needed for the fields to become searchable. -->
<localfile>
  <log_format>json</log_format>
  <location>/var/ossec/logs/mantis/siem-events.json</location>
</localfile>
