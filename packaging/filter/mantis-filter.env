# /etc/mantis-filter/mantis-filter.env — edit before starting the service.
# systemctl restart mantis-filter after changes.

RUST_LOG=info

# Control plane this node reports to and pulls policy bundles from.
CONTROL_URL=http://control.example.internal:8000

# Shared secret with the control plane (MANTIS_SERVICE_TOKEN in the control
# plane's own .env). Leave unset only if the control plane has none set.
MANTIS_SERVICE_TOKEN=

# Leave unset to run in multi-tenant source-IP routing mode. Set to pin this
# node to a single Kea DHCP-DDNS group instead.
GROUP_ID=

# Listen address:port for DNS queries. CAP_NET_BIND_SERVICE (granted by the
# unit file) allows binding :53 without running as root.
DNS_BIND_ADDR=0.0.0.0:53
