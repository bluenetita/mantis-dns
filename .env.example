# Copy this file to .env and fill in values before `docker compose up`.
# For local dev the defaults baked into docker-compose.yml are fine — you
# only need to override what's below. For anything MANTIS_ENV=production,
# every secret here MUST be set to a strong random value (main.py refuses
# to start otherwise).

# --- Postgres ---
POSTGRES_USER=mantis
POSTGRES_PASSWORD=mantis
POSTGRES_DB=mantis

# --- Control plane secrets ---
# Shared secret between control plane and filter/kea nodes (M2M auth).
# Generate with: openssl rand -hex 32
MANTIS_INTERNAL_TOKEN=dev-insecure-internal-token
MANTIS_SERVICE_TOKEN=dev-insecure-service-token

# JWT signing secret for user sessions. Generate with: openssl rand -hex 32
MANTIS_JWT_SECRET=

# HMAC secret for verifying inbound SIEM/webhook payloads.
MANTIS_WEBHOOK_SECRET_KEY=

# Set to "production" to enable strict secret checks on boot. Leave unset
# (or "development") for local docker compose use.
MANTIS_ENV=

# --- Initial admin user (seeded on first boot only) ---
ADMIN_EMAIL=admin@mantis.local
ADMIN_PASSWORD=change-me-now

# --- Filter node ---
# IP of the filter node the UI should point clients at (dashboard/status).
MANTIS_FILTER_NODE_IP=
# Kea DHCP-DDNS group to sync filter node with (leave blank for default group).
GROUP_ID=

# --- CORS (dev defaults already match the Vite dev server ports) ---
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:5174
